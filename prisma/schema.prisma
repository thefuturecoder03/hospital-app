datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

model User {
  id       String @id @default(uuid())
  email    String @unique
  password String
  role     String @default("STAFF")
}

model Patient {
  id            String   @id @default(uuid())
  name          String
  age           Int
  condition     String
  priorityScore Int
  isHighRisk    Boolean  @default(false)
  createdAt     DateTime @default(now())
  
  // Relational link definition to Room
  roomId        String?
  room          Room?    @relation(fields: [roomId], references: [id])
}

model Room {
  id          String    @id
  number      String    @unique
  type        String
  capacity    Int
  isAvailable Boolean   @default(true)
  
  // Back-reference relation list link for Prisma compliance
  patients    Patient[]
}
